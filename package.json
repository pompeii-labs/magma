{
	"name": "@pompeii-labs/magma",
	"version": "2.0.0",
	"description": "The Typescript framework to build AI agents quickly and easily",
	"keywords": [
		"Agents",
		"Typescript",
		"AI",
		"Agentic",
		"LLM",
		"Workflows",
		"Middleware"
	],
	"license": "Apache-2.0",
	"author": "Pompeii Labs, Inc.",
	"files": [
		"dist"
	],
	"repository": "pompeii-labs/magma",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./types": {
			"types": "./dist/types/index.d.ts",
			"default": "./dist/types/index.js"
		}
	},
	"scripts": {
		"build": "npm run format ; tsup",
		"dev": "tsup --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test": "bun test",
		"prepare": "husky"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.0",
		"@eslint/js": "^9.39.1",
		"@swc/core": "^1.5.1",
		"@types/bun": "^1.3.6",
		"eslint": "^9.39.1",
		"husky": "^9.1.7",
		"prettier": "^3.2.5",
		"tsup": "^8.0.2",
		"typescript": "^5.6.2",
		"typescript-eslint": "^8.49.0",
		"zod": "^4.2.1"
	},
	"peerDependencies": {
		"ai": "^6.0.41"
	}
}
